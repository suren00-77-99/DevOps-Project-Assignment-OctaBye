pipeline {

    agent any

    environment {

        AWS_REGION = "ap-south-1"

        ECR_REPO = "xxxxxxxx.dkr.ecr.ap-south-1.amazonaws.com/8byte-app"

        ECS_CLUSTER = "8byte-cluster"

        ECS_SERVICE = "8byte-service"

    }

    stages {

        stage('Checkout') {

            steps {

                checkout scm

            }

        }

        stage('Unit Test') {

            steps {

                dir('app') {

                    sh '''

                    python -m py_compile app.py

                    '''

                }

            }

        }

        stage('Build Docker Image') {

            steps {

                dir('app') {

                    sh '''

                    docker build -t 8byte-app .

                    '''

                }

            }

        }

        stage('Trivy Scan') {

            steps {

                sh '''

                trivy image 8byte-app

                '''

            }

        }

        stage('Login to ECR') {

            steps {

                sh '''

                aws ecr get-login-password \
                --region $AWS_REGION |

                docker login \
                --username AWS \
                --password-stdin $ECR_REPO

                '''

            }

        }

        stage('Push Image') {

            steps {

                sh '''

                docker tag 8byte-app:latest \
                $ECR_REPO:latest

                docker push \
                $ECR_REPO:latest

                '''

            }

        }

        stage('Deploy Staging') {

            steps {

                sh '''

                aws ecs update-service \
                --cluster $ECS_CLUSTER \
                --service $ECS_SERVICE \
                --force-new-deployment

                '''

            }

        }

        stage('Production Approval') {

            steps {

                input(
                    message: "Deploy To Production?",
                    ok: "Deploy"
                )

            }

        }

        stage('Production Deployment') {

            steps {

                sh '''

                aws ecs update-service \
                --cluster $ECS_CLUSTER \
                --service $ECS_SERVICE \
                --force-new-deployment

                '''

            }

        }

    }

}